# Copy this file to /volume1/docker/personal-os-agent/data/secrets/agent-server.env
# Fill real values on the NAS. Do not commit real *.env files.

# Enables Basic Auth for /v1/*, /docs, /redoc, and /openapi.json.
# Leave both blank only for local development.
AGENT_SERVER_USERNAME=
AGENT_SERVER_PASSWORD=

RADIO_OUTPUT_DIR=/data/radio
DAOLIYU_MEDIA_ROOT=/data/media/daoliyu
MUSIC_LIBRARY_ROOTS=/data/media/daoliyu,/data/media/sqmusic,/data/media/local
MUSIC_COVER_DIR=/data/covers

# MiniMax Token Plan subscription key. Preferred for Token Plan usage.
MINIMAX_SUBSCRIPTION_KEY=

# Pay-as-you-go fallback only. Token Plan keys and API keys are not interchangeable.
MINIMAX_API_KEY=

MINIMAX_GROUP_ID=
MINIMAX_CHAT_MODEL=MiniMax-M3
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=male-qn-jingying

RADIO_DAILY_ENABLED=true
RADIO_DAILY_TIME=07:30
RADIO_DAILY_TIMEZONE=Asia/Shanghai
RADIO_WEATHER_CITY=陕西西安
RADIO_WEATHER_LAT=34.3416
RADIO_WEATHER_LON=108.9398
RADIO_RECENT_LIMIT=30
