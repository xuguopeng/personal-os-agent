# Personal listening-source secrets.
# Copy this file to music-sources.env and fill values locally or on NAS.
# Do not commit music-sources.env.

# Comma-separated directories where the server searches for private plugins.
LISTENING_PLUGIN_DIRS=/data/private_plugins/music_sources,./services/agent-server/private_plugins,./private_plugins
METADATA_PLUGIN_DIRS=/data/private_plugins/music_metadata,./services/agent-server/private_plugins,./private_plugins

# NetEase Cloud Music private plugin inputs.
# The first supported path is copied API/JSON listening-rank data.
NETEASE_HISTORY_JSON=/data/private_exports/netease-history.json

# Optional personal-only values for a future private NetEase collector.
# NETEASE_MUSIC_COOKIE=your-netease-cookie
# NETEASE_MUSIC_USER_ID=your-netease-user-id

# QQ Music / Kugou / Kuwo:
# Their web pages do not currently provide reliable personal playback-history
# records in this workflow. Keep them as normalized imports or client-side
# playback capture sources instead of assuming cookie sync works.

# Optional import files for personal local conversion scripts.
# QQ_HISTORY_JSON=/data/private_exports/qq-history.json
# KUGOU_HISTORY_JSON=/data/private_exports/kugou-history.json
# KUWO_HISTORY_JSON=/data/private_exports/kuwo-history.json

# Optional local metadata candidate file for the private local_metadata provider.
# Keep the real JSON outside git.
# MUSIC_METADATA_JSON=/data/private_exports/metadata-candidates.json

# Optional personal sqmusic metadata provider.
# Put the real provider in an ignored private plugin directory as sqmusic_metadata.py.
# SQMUSIC_BASE_URL=http://192.168.10.21:8096
# SQMUSIC_USERNAME=your-sqmusic-username
# SQMUSIC_PASSWORD=your-sqmusic-password
# SQMUSIC_PLUG_NAMES=kw,qq,netease,kg,mg
# SQMUSIC_PREFERRED_BR_TYPES=KW_FLAC_2000,QQVIP_Flac_2000,QQ_Flac_2000,KG_Flac_3000,NETEASE_FLAC_3000,KW_MP3_320,QQVIP_MP3_320,QQ_MP3_320,KG_MP3_320,NETEASE_MP3_320,KW_MP3_128,QQ_MP3_128
